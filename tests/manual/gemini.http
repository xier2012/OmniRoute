###
# @name OpenAI Response - Test streaming response
POST {{omniroute-address}}/v1/responses
Authorization: Bearer {{OMNIROUTE_API_KEY}}
Content-Type: application/json

{
  "model": "gemini/gemma-4-31b-it",
  "stream": true,
  "input": [
    {
      "type": "message",
      "role": "user",
      "content": [
        {
          "type": "input_text",
          "text": "Ansver 1+1 only."
        }
      ]
    }
  ]
}

