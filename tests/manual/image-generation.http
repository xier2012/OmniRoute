###
# @name Omniroute - Generate Image
POST {{omniroute-address}}/v1/images/generations
Authorization: Bearer {{OMNIROUTE_API_KEY}}
Content-Type: application/json

{
  "prompt": "Happy red kitten",
  "model": "pol/zimage",
  "n": 1,
  "size": "1024x1024",
  "quality": "medium",
  "response_format": "b64_json",
  "user": "",
  "image": ""
}

